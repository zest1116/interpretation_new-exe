<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	 xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
	<Fragment>
		<?define PublishDir = "$(var.SolutionDir)Publish\" ?>
		<?define ExeName = "axink Translator.exe" ?>
		<?define FolderName = "axink Translator" ?>
		<?define DisplayName = "a:xink Translator" ?>

		<!-- 레지스트리 정보 (앱에서 설치 경로 조회용) -->
		<ComponentGroup Id="RegistryComponents" Directory="INSTALLFOLDER">
			<Component Id="RegistryEntries" Guid="*">
				<RegistryKey Root="HKCU" Key="Software\LGCNS\$(FolderName)">
					<RegistryValue Name="InstallPath" Type="string" Value="[INSTALLFOLDER]" KeyPath="yes" />
					<RegistryValue Name="Version" Type="string" Value="!(bind.fileVersion.MainExeFile)" />
				</RegistryKey>

				<!-- 제어판 "프로그램 및 기능"에 a:xink 로 표시 (MSI 기본값 덮어쓰기) -->
				<RegistryValue Root="HKCU"
							   Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\[ProductCode]"
							   Name="DisplayName"
							   Type="string"
							   Value="$(DisplayName)" />

				<RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
				<RemoveFolder Id="RemoveManufacturerFolder" Directory="ManufacturerFolder" On="uninstall" />
			</Component>
			<!-- ✅ 환경변수 추가 -->
			<Component Id="Comp_EnvVariable" Guid="*">
				<Environment Id="Env_AxinkEnvironment"
							 Name="AXINK_ENVIRONMENT"
							 Value="$(var.AppEnvironment)"
							 Permanent="no"
							 Part="all"
							 Action="set"
							 System="no" />
				<RegistryValue Root="HKCU"
							   Key="Software\LGCNS\$(FolderName)"
							   Name="EnvVariable"
							   Type="integer"
							   Value="1"
							   KeyPath="yes" />
			</Component>
		</ComponentGroup>

		<!-- 바로가기 -->
		<ComponentGroup Id="ShortcutComponents">
			<!-- 시작 메뉴 바로가기 -->
			<Component Id="StartMenuShortcut" Directory="ApplicationMenuFolder" Guid="*">
				<Shortcut Id="StartMenuShortcutLink"
                          Name="$(FolderName)"
                          Description="$(DisplayName) 실행"
                          Target="[INSTALLFOLDER]$(ExeName)"
                          WorkingDirectory="INSTALLFOLDER"
                          Icon="ProductIcon" />

				<Shortcut Id="UninstallShortcut"
                          Name="$(FolderName) 제거"
                          Description="$(DisplayName) 제거"
                          Target="[SystemFolder]msiexec.exe"
                          Arguments="/x [ProductCode]" />

				<RemoveFolder Id="RemoveApplicationMenuFolder" On="uninstall" />

				<RegistryValue Root="HKCU"
                               Key="Software\LGCNS\$(FolderName)"
                               Name="StartMenuShortcut"
                               Type="integer"
                               Value="1"
                               KeyPath="yes" />
			</Component>

			<!-- 바탕화면 바로가기 -->
			<Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="*">
				<Shortcut Id="DesktopShortcutLink"
                          Name="$(FolderName)"
                          Description="$(DisplayName) 실행"
                          Target="[INSTALLFOLDER]$(ExeName)"
                          WorkingDirectory="INSTALLFOLDER"
                          Icon="ProductIcon" />

				<RegistryValue Root="HKCU"
                               Key="Software\LGCNS\$(FolderName)"
                               Name="DesktopShortcut"
                               Type="integer"
                               Value="1"
                               KeyPath="yes" />
			</Component>
		</ComponentGroup>
	</Fragment>
</Wix>
