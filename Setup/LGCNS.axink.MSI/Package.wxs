<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	 xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
	<!-- ★ UpgradeCode는 절대 변경하지 않음! 한번 생성 후 고정 ★ -->
	<?define UpgradeCode = "C2098732-0E0A-4099-B14A-EA62A0AE55A3" ?>
	<?define Manufacturer = "LGCNS" ?>
	<?define ProductName = "axink Translator" ?>
	<?define DisplayName = "a:xink Translator" ?>
	<?define ExeName = "axink Translator.exe" ?>

	<Package Id="LGCNS.axink.Installer"
			 Name="$(ProductName)"
			 Manufacturer="$(Manufacturer)"
			 Version="!(bind.fileVersion.MainExeFile)"
			 UpgradeCode="$(UpgradeCode)"
			 Compressed="yes"
			 InstallerVersion="500"
			 Scope="perUser"
			 Language="!(loc.LanguageCode)"
			 Codepage="!(loc.Codepage)">

		<!-- 요약 정보 -->
		<SummaryInformation
			Description="!(loc.SummaryDescription)"
            Manufacturer="$(Manufacturer)" />

		<!-- ★ 업그레이드 핵심 설정 (다국어 MSI 대응) ★ -->
		<Upgrade Id="$(UpgradeCode)">
			<!-- 이전 버전 검색: 모든 언어 LCID 명시 -->
			<UpgradeVersion
				Minimum="0.0.0.0"
				IncludeMinimum="yes"
				Maximum="!(bind.fileVersion.MainExeFile)"
				IncludeMaximum="no"
				Language="1033,1042,2052"
				Property="OLDER_VERSION_FOUND"
				MigrateFeatures="yes" />

			<!-- 같은 버전 재설치 허용 -->
			<UpgradeVersion
				Minimum="!(bind.fileVersion.MainExeFile)"
				IncludeMinimum="yes"
				Maximum="!(bind.fileVersion.MainExeFile)"
				IncludeMaximum="yes"
				Language="1033,1042,2052"
				Property="SAME_VERSION_FOUND"
				MigrateFeatures="yes" />

			<!-- 다운그레이드 차단: 새 버전 탐지 -->
			<UpgradeVersion
				Minimum="!(bind.fileVersion.MainExeFile)"
				IncludeMinimum="no"
				OnlyDetect="yes"
				Language="1033,1042,2052"
				Property="NEWER_VERSION_FOUND" />
		</Upgrade>

		<!-- 다운그레이드 차단 메시지 -->
		<Launch
			Condition="NOT NEWER_VERSION_FOUND"
			Message="!(loc.DowngradeError)" />

		<!-- RemoveExistingProducts 시점 (per-user 같은 폴더 설치에 적합) -->
		<InstallExecuteSequence>
			<RemoveExistingProducts After="InstallInitialize" />
		</InstallExecuteSequence>
		
		<!-- 단일 MSI 파일로 압축 -->
		<MediaTemplate EmbedCab="yes" CompressionLevel="high" />

		<!-- 설치 UI -->
		<UI>
			<ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
			<Publish Dialog="ExitDialog"
             Control="Finish"
             Event="DoAction"
             Value="LaunchApplication"
             Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
		</UI>

		<!-- UI 리소스 -->
		<WixVariable Id="WixUIDialogBmp" Value="WixUIDialogBmp.bmp" />
		<WixVariable Id="WixUIBannerBmp" Value="WixUIBannerBmp.bmp" />
		<WixVariable Id="WixUILicenseRtf" Value="!(loc.WixUILicenseRtf)" />
		
		<!-- 제어판 아이콘 -->
		<Icon Id="ProductIcon" SourceFile="ProductIcon.ico" />
		<Property Id="ARPPRODUCTICON" Value="ProductIcon" />
		<Property Id="ARPHELPLINK" Value="https://www.lgcns.com/" />
		<Property Id="ARPURLINFOABOUT" Value="https://www.lgcns.com/" />
				
		<!-- 설치 후 앱 실행 옵션 -->
		<Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

		<!-- 실행 대상 지정 -->
		<Property Id="WixShellExecTarget" Value="[INSTALLFOLDER]$(ExeName)" />

		<!-- CustomAction 정의 -->
		<CustomAction Id="LaunchApplication"
					  DllEntry="WixShellExec"
					  Impersonate="yes"
					  BinaryRef="Wix4UtilCA_X64" />

		<Feature Id="MainFeature"
				 Title="$(DisplayName)"
                 Level="1"
                 ConfigurableDirectory="INSTALLFOLDER">
			<ComponentGroupRef Id="RegistryComponents" />
			<ComponentGroupRef Id="ShortcutComponents" />
			<ComponentGroupRef Id="PublishedComponents" />
			<ComponentGroupRef Id="UpdaterComponents" />
		</Feature>
	</Package>
</Wix>
