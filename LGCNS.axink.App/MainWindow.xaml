<Window x:Class="LGCNS.axink.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="axink"
        Width="800"
        Height="600"
        MinWidth="600"
        MinHeight="800"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#F3F3F3"
        AllowsTransparency="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid"
          Background="{StaticResource WindowBackgroundBrush}">

        <Border x:Name="MainFrame"
                Margin="1"
                Background="{StaticResource WindowBackgroundBrush}"
                BorderBrush="{StaticResource WindowBorderBrush}"
                BorderThickness="0"
                CornerRadius="10"
                SnapsToDevicePixels="True">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Border x:Name="TitleBarBorder"
                        Grid.Row="0"
                        Background="{StaticResource TitleBarBrush}"
                        BorderThickness="0,0,0,0"
                        CornerRadius="10,10,0,0">
                    <Grid x:Name="TitleBar"
                          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 좌측 앱 아이콘 + 제목 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="10,0,0,0"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Image x:Name="AppIconImage"
                                   Width="25"
                                   Height="25"
                                   Margin="0,0,8,0"
                                   Stretch="Uniform"
                                   Source="/Assets/LGCNS.DesktopAudioHub.App.png" RenderOptions.BitmapScalingMode="HighQuality"/>

                            <TextBlock Text="a:xink Translator"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TitleForegroundBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- 드래그 영역 -->
                        <Grid Grid.Column="1" Background="Transparent"/>

                        <!-- 우측 버튼 -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">

                            <!-- 최소화 -->
                            <Button Style="{StaticResource CaptionButtonStyle}"
                                    Click="Minimize_Click">
                                <Grid Width="10" Height="10">
                                    <Rectangle Height="1.2"
                                               Width="10"
                                               RadiusX="0"
                                               RadiusY="0"
                                               VerticalAlignment="Center"
                                               Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Grid>
                            </Button>

                            <!-- 최대화 / 복원 -->
                            <Button x:Name="MaxBtn"
                                    Style="{StaticResource CaptionButtonStyle}"
                                    Click="Maximize_Click">
                                <Grid Width="10" Height="10">
                                    <!-- 최대화 -->
                                    <Rectangle x:Name="MaximizeGlyph"
                                               Width="9"
                                               Height="9"
                                               StrokeThickness="1"
                                               Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               Fill="Transparent"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <!-- 복원 -->
                                    <Grid x:Name="RestoreGlyph" Visibility="Collapsed">
                                        <Rectangle Width="7"
                                                   Height="7"
                                                   Margin="0,2,2,0"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Top"
                                                   StrokeThickness="1"
                                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                   Fill="Transparent"/>
                                        <Rectangle Width="7"
                                                   Height="7"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Bottom"
                                                   StrokeThickness="1"
                                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                   Fill="Transparent"/>
                                    </Grid>
                                </Grid>
                            </Button>

                            <!-- 닫기 -->
                            <Button Style="{StaticResource CloseButtonStyle}"
                                    Click="Close_Click">
                                <Grid Width="10" Height="10">
                                    <Path Data="M 1,1 L 9,9 M 9,1 L 1,9"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.2"
                                          StrokeStartLineCap="Square"
                                          StrokeEndLineCap="Square"
                                          SnapsToDevicePixels="True"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content -->
                <Border x:Name="ContentBorder"
                        Grid.Row="1"
                        Background="{StaticResource ContentBackgroundBrush}"
                        CornerRadius="0,0,10,10"
                        ClipToBounds="True">
                    <wv2:WebView2 x:Name="WebView" HorizontalAlignment="Stretch"   VerticalAlignment="Stretch"/>
                    <!--<StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                        <Ellipse Width="56" Height="56"
                         Stroke="#DADCE0" StrokeThickness="1.5"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,12"/>
                        <TextBlock Text="WebView2 content area"
                           Foreground="#9AA0A6" FontSize="13"
                           HorizontalAlignment="Center"/>
                    </StackPanel>-->
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>