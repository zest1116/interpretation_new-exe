<Window x:Class="LGCNS.axink.Updater.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="axink 업데이트"
        Width="480" Height="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <Border CornerRadius="12"
            Background="#FFFFFF"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            Padding="36,28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="3" Opacity="0.15" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 아이콘 + 제목 -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <!-- 상태 메시지 -->
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <!-- 상세 정보 -->
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <!-- 프로그레스 바 -->
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <!-- 퍼센트 + 크기 -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <!-- 하단 버튼 -->
            </Grid.RowDefinitions>

            <!-- 제목 영역 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- 앱 아이콘 영역 (원형 배경) -->
                <Border Width="36" Height="36" CornerRadius="18" Background="#F0EDFF" Margin="0,0,12,0">
                    <TextBlock Text="⟳" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#6B5CE7" FontWeight="Bold"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               Text="업데이트 준비 중..."
                               FontSize="17" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                    <TextBlock x:Name="VersionText"
                               Text=""
                               FontSize="12" Foreground="#8E8EA0" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- 상태 메시지 -->
            <TextBlock Grid.Row="2"
                       x:Name="StatusText"
                       Text="앱 종료를 기다리고 있습니다..."
                       FontSize="13" Foreground="#4A4A5A"/>

            <!-- 상세 정보 (다운로드 크기 등) -->
            <TextBlock Grid.Row="4"
                       x:Name="DetailText"
                       Text=""
                       FontSize="12" Foreground="#8E8EA0"/>

            <!-- 프로그레스 바 -->
            <Grid Grid.Row="6">
                <ProgressBar x:Name="MainProgress"
                             Height="6" Minimum="0" Maximum="100" Value="0"
                             Background="#F0F0F5">
                    <ProgressBar.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#6B5CE7" Offset="0"/>
                            <GradientStop Color="#8B7CF7" Offset="1"/>
                        </LinearGradientBrush>
                    </ProgressBar.Foreground>
                </ProgressBar>
            </Grid>

            <!-- 퍼센트 표시 -->
            <Grid Grid.Row="8">
                <TextBlock x:Name="PercentText"
                           Text=""
                           FontSize="12" Foreground="#8E8EA0"
                           HorizontalAlignment="Left"/>
                <TextBlock x:Name="SizeText"
                           Text=""
                           FontSize="12" Foreground="#8E8EA0"
                           HorizontalAlignment="Right"/>
            </Grid>

            <!-- 하단 에러 시 재시도/닫기 버튼 -->
            <StackPanel Grid.Row="10" Orientation="Horizontal"
                        HorizontalAlignment="Right" Visibility="Collapsed"
                        x:Name="ButtonPanel">
                <Button x:Name="RetryButton" Content="{DynamicResource Dic_Common_Retry}"
                        Width="80" Height="32" Margin="0,0,8,0"
                        FontSize="13" Cursor="Hand"
                        Click="RetryButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#6B5CE7"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="12,6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="CloseButton" Content="{DynamicResource Dic_Common_Close}"
                        Width="80" Height="32"
                        FontSize="13" Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#F0F0F5"/>
                            <Setter Property="Foreground" Value="#4A4A5A"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="12,6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
