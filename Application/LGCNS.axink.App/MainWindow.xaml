<Window x:Class="LGCNS.axink.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="axink"
        Width="600"
        Height="1000"
        MinWidth="600"
        MinHeight="1000"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        AllowsTransparency="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="10"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid"
          Background="{DynamicResource WindowBackgroundBrush}">

        <Border x:Name="MainFrame"
                Margin="1"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource WindowBorderBrush}"
                BorderThickness="0"
                CornerRadius="10"
                SnapsToDevicePixels="True">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Border x:Name="TitleBarBorder"
                        Grid.Row="0"
                        Background="{DynamicResource TitleBarBackgroundBrush}"
                        BorderThickness="0"
                        CornerRadius="10,10,0,0">
                    <Grid x:Name="TitleBar"
                          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 좌측 앱 아이콘 + 제목 -->
                        <Grid x:Name="TitleLeftHost"
                              Grid.Column="0"
                              VerticalAlignment="Stretch"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="12,0,0,0">
                                <Border Width="16"
                                        Height="16"
                                        VerticalAlignment="Center"
                                        Background="Transparent">
                                    <Image x:Name="AppIconImage"
                                           Width="16"
                                           Height="16"
                                           Stretch="Uniform"
                                           Source="/Assets/LGCNS.DesktopAudioHub.App.png"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <TextBlock Text="a:xink Translator"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TitleBarForegroundBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>

                        <!-- 드래그 영역 -->
                        <Grid Grid.Column="1"
                              Background="Transparent"/>

                        <!-- 우측 버튼 -->
                        <StackPanel x:Name="CaptionButtonsHost"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Stretch"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">

                            <!-- 최소화 -->
                            <Button Style="{DynamicResource CaptionButtonStyle}"
                                    Click="Minimize_Click">
                                <Grid Width="10" Height="10" Margin="0,-1,0,0">
                                    <Rectangle Height="1"
                                               Width="10"
                                               VerticalAlignment="Center"
                                               Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Grid>
                            </Button>

                            <!-- 최대화 / 복원 -->
                            <Button x:Name="MaxBtn"
                                    Style="{DynamicResource CaptionButtonStyle}"
                                    Click="Maximize_Click">
                                <Grid Width="10" Height="10" Margin="0,-1,0,0">
                                    <Path x:Name="MaximizeGlyph"
                                          Data="M1.5,1.5 L8.5,1.5 L8.5,8.5 L1.5,8.5 Z"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1"
                                          SnapsToDevicePixels="True"
                                          Stretch="Fill"/>

                                    <Grid x:Name="RestoreGlyph" Visibility="Collapsed">
                                        <Path Data="M3,1.5 L8.5,1.5 L8.5,7"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1"
                                              Fill="Transparent"
                                              SnapsToDevicePixels="True"/>
                                        <Path Data="M1.5,3 L7,3 L7,8.5 L1.5,8.5 Z"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1"
                                              Fill="Transparent"
                                              SnapsToDevicePixels="True"/>
                                    </Grid>
                                </Grid>
                            </Button>

                            <!-- 닫기 -->
                            <Button Style="{DynamicResource CloseButtonStyle}"
                                    Click="Close_Click">
                                <Grid Width="10" Height="10" Margin="0,-1,0,0">
                                    <Path Data="M 1,1 L 9,9 M 9,1 L 1,9"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.1"
                                          StrokeStartLineCap="Square"
                                          StrokeEndLineCap="Square"
                                          SnapsToDevicePixels="True"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Menu Bar -->
                <Border Grid.Row="1"
                        Background="{DynamicResource MenuBarBackgroundBrush}"
                        Padding="4,0,0,0">
                    <Menu Style="{DynamicResource MenuBarStyle}"
                          VerticalAlignment="Center">
                        <MenuItem Header="{DynamicResource Dic_Menu_File}" Style="{DynamicResource MenuItemTopLevelStyle}">
                            <MenuItem Header="{DynamicResource Dic_Menu_Config}" Style="{DynamicResource SubMenuItemStyle}" Click="Config_Click"/>
                            <MenuItem Header="{DynamicResource Dic_Menu_Audio}" Style="{DynamicResource SubMenuItemStyle}" Click="AuditoDevice_Click"/>
                            <MenuItem Header="{DynamicResource Dic_CompanySelect}" Style="{DynamicResource SubMenuItemStyle}" Click="CompanySelect_Click"/>
                            <MenuItem Header="{DynamicResource Dic_Menu_Theme}" Style="{DynamicResource SubMenuItemStyle}">
                                <MenuItem x:Name="LightThemeMenuItem"
                                          Header="Light"
                                          IsCheckable="True"
                                          Click="ThemeMenuItem_Click"
                                          Tag="Light"/>

                                <MenuItem x:Name="DarkThemeMenuItem"
                                          Header="Dark"
                                          IsCheckable="True"
                                          Click="ThemeMenuItem_Click"
                                          Tag="Dark"/>
                            </MenuItem>
                            <Separator Style="{DynamicResource SubMenuSeparatorStyle}"/>
                            <MenuItem Header="{DynamicResource Dic_Menu_Close}" Style="{DynamicResource SubMenuItemStyle}" Click="Exit_Click"/>
                        </MenuItem>
                    </Menu>
                </Border>

                <!-- Content -->
                <Border x:Name="ContentBorder"
                        Grid.Row="2"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        CornerRadius="0,0,10,10"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="8"/>
                        </Grid.RowDefinitions>

                        <wv2:WebView2  Grid.Row="0" x:Name="WebView"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                        <!-- 하단 리사이즈용 여유 영역 -->
                        <Border Grid.Row="1"
                            Background="Transparent"
                            IsHitTestVisible="False"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>