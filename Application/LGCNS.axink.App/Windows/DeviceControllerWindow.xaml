<Window x:Class="LGCNS.axink.App.Windows.DeviceControllerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:LGCNS.axink.App.Controls"
        mc:Ignorable="d"
        Title="{DynamicResource Dic_Title_Audio}"
        Width="540"
        Height="800"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        PreviewKeyDown="Window_PreviewKeyDown"        
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        AllowsTransparency="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="10"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid SnapsToDevicePixels="True"
          UseLayoutRounding="True">
        <Border Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource WindowBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                SnapsToDevicePixels="True" 
                UseLayoutRounding="True"
                RenderOptions.EdgeMode="Unspecified"
                RenderOptions.BitmapScalingMode="HighQuality">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="55"/>
                </Grid.RowDefinitions>

                <controls:ThemedTitleBar Grid.Row="0" Title="{DynamicResource Dic_Menu_Audio}"/>

                <Grid Grid.Row="1" Margin="20,10,20,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 안내 -->
                    <Border Grid.Row="0" Style="{StaticResource SettingsGuideCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Dic_Title_Audio}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{DynamicResource Dic_Title_Audio_Desc}"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 섹션 -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Speaker -->
                        <Border Grid.Row="0" Style="{StaticResource SettingsSectionCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="38"
                                            Height="38"
                                            CornerRadius="10"
                                            Background="{DynamicResource SpeakerAccentBackgroundBrush}">
                                        <Path Data="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"
                                              Fill="{DynamicResource SpeakerAccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Dic_Device_Speaker}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Dic_Device_Speaker_SubTitle}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <ScrollViewer Grid.Row="2"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    
                                    <ItemsControl x:Name="SpeakerList"
                                                  ItemTemplate="{StaticResource ModernDeviceItemTemplate}"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Mic -->
                        <Border Grid.Row="2" Style="{StaticResource SettingsSectionCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="38"
                                            Height="38"
                                            CornerRadius="10"
                                            Background="{DynamicResource MicAccentBackgroundBrush}">
                                        <Path Data="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"
                                              Fill="{DynamicResource MicAccentBrush}"
                                              Stretch="Uniform"
                                              Width="16"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Dic_Device_Mic}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Dic_Device_Mic_SubTitle}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <ScrollViewer Grid.Row="2"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">

                                    <ItemsControl x:Name="MicList"
                                                  ItemTemplate="{StaticResource ModernDeviceItemTemplate}"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Footer -->
                <Border Grid.Row="2"
                        Style="{StaticResource DialogFooterBarStyle}"
                        CornerRadius="0,0,10,10"
                        Padding="20,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!--<TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="장치를 클릭하면 즉시 기본 장치가 변경됩니다."/>-->

                        <Button Grid.Column="1"
                                Content="{DynamicResource Dic_Common_Ok}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Click="Confirm_Click"
                                IsDefault="True"
                                Width="96"
                                Height="38"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>