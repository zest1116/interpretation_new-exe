<Window x:Class="LGCNS.axink.App.Windows.DeviceControllerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LGCNS.axink.App.Windows"
        mc:Ignorable="d"
        Title="{DynamicResource Dic_Title_Audio}"
        Width="460"
        Height="650"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F7F9FC"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate x:Key="DeviceItemTemplate">
            <Border Style="{StaticResource DeviceItemBorder}"
                MouseLeftButtonDown="Device_Click"
                Tag="{Binding}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           FontSize="13"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#374151"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                        <Setter Property="Foreground" Value="#2F6FED"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Column="1"
                           Text="✓ 기본"
                           FontSize="11"
                           Foreground="#2F6FED"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="8,0,4,0"
                           Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="10,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>

        <!-- 스피커 타이틀 -->
        <TextBlock Grid.Row="0"
                   FontSize="14" FontWeight="Bold" Foreground="#1F2937"
                   Margin="2,0,0,8">
            <Run Text="🔊"/>
            <Run Text="{DynamicResource Dic_Device_Speaker}"/>
        </TextBlock>

        <!-- 스피커 목록 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="14, 0">
            <ItemsControl x:Name="SpeakerList"
                          ItemTemplate="{StaticResource DeviceItemTemplate}"/>
        </ScrollViewer>

        <!-- 구분선 -->
        <Separator Grid.Row="2" VerticalAlignment="Center" Background="#E5E7EB"/>

        <!-- 마이크 타이틀 -->
        <TextBlock Grid.Row="3"
                   FontSize="14" FontWeight="Bold" Foreground="#1F2937"
                   Margin="2,0,0,8">
            <Run Text="🎤"/>
            <Run Text="{DynamicResource Dic_Device_Mic}"/>
        </TextBlock>

        <!-- 마이크 목록 -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Margin="14, 0">
            <ItemsControl x:Name="MicList"
                          ItemTemplate="{StaticResource DeviceItemTemplate}"/>
        </ScrollViewer>

        <StackPanel Grid.Row="6"
            Orientation="Horizontal"
            HorizontalAlignment="Center">
            <Button Content="확인"
            Style="{StaticResource PrimaryButtonStyle}"
            Click="Confirm_Click"
            IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
