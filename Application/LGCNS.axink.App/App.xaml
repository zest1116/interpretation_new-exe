<Application x:Class="LGCNS.axink.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LGCNS.axink.App"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            
            <ResourceDictionary.MergedDictionaries>
                <!-- 라이트/다크 중 하나만 선택 -->
                <ResourceDictionary Source="/Themes/ThemeLight.xaml"/>
                <!-- <ResourceDictionary Source="Themes/ThemeDark.xaml"/> -->

                <ResourceDictionary Source="/Themes/Fonts.xaml"/>

                <ResourceDictionary Source="/Themes/Styles/Common.xaml"/>
                <ResourceDictionary Source="/Themes/Styles/Buttons.xaml"/>
                <ResourceDictionary Source="/Themes/Styles/Menu.xaml"/>
                <ResourceDictionary Source="/Themes/Styles/TitleBar.xaml"/>
                <ResourceDictionary Source="/Themes/Styles/ScrollBar.xaml"/>
                <ResourceDictionary Source="/Themes/Styles/DeviceControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
