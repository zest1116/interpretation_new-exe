<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#26000000"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#FFFFFF"/>

    <!-- TitleBar -->
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#E6F4FF"/>
    <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="#1F2937"/>

    <!-- Caption Buttons -->
    <SolidColorBrush x:Key="CaptionButtonHoverBrush" Color="#E8F0FB"/>
    <SolidColorBrush x:Key="CaptionButtonPressedBrush" Color="#DCE7F7"/>
    <SolidColorBrush x:Key="CloseButtonHoverBrush" Color="#E81123"/>

    <!-- Menu -->
    <SolidColorBrush x:Key="MenuBarBackgroundBrush" Color="#F8FBFF"/>
    <SolidColorBrush x:Key="MenuHoverBrush" Color="#E8F2FF"/>
    <SolidColorBrush x:Key="MenuPressedBrush" Color="#DCEAFF"/>
    <SolidColorBrush x:Key="MenuPopupBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MenuPopupBorderBrush" Color="#D7E6F2"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="TextErrorBrush" Color="#DC2626"/>

    <!-- Primary Button -->
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#2F6FED"/>
    <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#255ED1"/>
    <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#1F4FAF"/>
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFF"/>

    <!-- Secondary Button -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#25324B"/>
    <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#D0D7E2"/>
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#F3F6FB"/>
    <SolidColorBrush x:Key="SecondaryButtonPressedBrush" Color="#E8EEF8"/>

    <!-- Danger / Cancel -->
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DangerButtonForegroundBrush" Color="#D92D20"/>
    <SolidColorBrush x:Key="DangerButtonBorderBrush" Color="#D92D20"/>
    <SolidColorBrush x:Key="DangerButtonHoverBrush" Color="#FEF3F2"/>
    <SolidColorBrush x:Key="DangerButtonPressedBrush" Color="#FEE4E2"/>

    <!-- Device Item -->
    <SolidColorBrush x:Key="DeviceDefaultBorderBrush" Color="#2F6FED"/>
    <SolidColorBrush x:Key="DeviceDefaultBackgroundBrush" Color="#F3F6FB"/>
    <SolidColorBrush x:Key="DeviceHoverBrush" Color="#F3F6FB"/>
    <SolidColorBrush x:Key="DeviceDefaultHoverBrush" Color="#DCEAFF"/>

    <!-- Device Text -->
    <SolidColorBrush x:Key="DeviceTextNormalBrush" Color="#374151"/>
    <SolidColorBrush x:Key="DeviceTextDefaultBrush" Color="#2F6FED"/>
    <SolidColorBrush x:Key="DeviceTextSubBrush" Color="#9AA4B2"/>

    <!-- Dialog -->
    <SolidColorBrush x:Key="DialogBackgroundBrush" Color="#F7F9FC"/>
    <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DialogBorderBrush" Color="#E5E7EB"/>

    <!-- Input -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#D0D7E2"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#2F6FED"/>
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#9AA4B2"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2F6FED"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#255ED1"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#1F4FAF"/>
    <SolidColorBrush x:Key="AccentBackgroundBrush" Color="#EBF2FF"/>
    <SolidColorBrush x:Key="AccentStrokeBrush" Color="#B8D4FE"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#D0D7E2"/>
    <SolidColorBrush x:Key="ComboBoxHoverBrush" Color="#F3F6FB"/>
    <SolidColorBrush x:Key="ComboBoxDropdownBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#EBF2FF"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#DCEAFF"/>

    <!-- General -->
    <SolidColorBrush x:Key="SeparatorBrush" Color="#D9D9D9"/>

    <CornerRadius x:Key="CornerRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLarge">10</CornerRadius>

    <Thickness x:Key="ControlPadding">18,0</Thickness>
    <Thickness x:Key="DialogPadding">20</Thickness>

    <!-- Settings / Panels -->
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="PanelSubtleBackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#FCFCFD"/>

    <!-- Device Section Accent -->
    <SolidColorBrush x:Key="SpeakerAccentBrush" Color="#4F46E5"/>
    <SolidColorBrush x:Key="SpeakerAccentBackgroundBrush" Color="#EEF2FF"/>
    <SolidColorBrush x:Key="MicAccentBrush" Color="#059669"/>
    <SolidColorBrush x:Key="MicAccentBackgroundBrush" Color="#ECFDF5"/>

    <!-- Device Item Extended -->
    <SolidColorBrush x:Key="DeviceItemBorderBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="DeviceSelectedBackgroundBrush" Color="#EFF6FF"/>
    <SolidColorBrush x:Key="DeviceSelectedBorderBrush" Color="#BFDBFE"/>
    <SolidColorBrush x:Key="DeviceBadgeBackgroundBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="DeviceBadgeForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DeviceStatusIdleBrush" Color="#9CA3AF"/>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#14000000"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#7A6B7280"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#A06B7280"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#C04B5563"/>

    <!-- Notification -->
    <SolidColorBrush x:Key="NotificationBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NotificationBorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="NotificationTitleBrush" Color="#111827"/>
    <SolidColorBrush x:Key="NotificationMessageBrush" Color="#4B5563"/>
    <SolidColorBrush x:Key="NotificationShadowBrush" Color="#000000"/>

    <SolidColorBrush x:Key="NotificationInfoAccentBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="NotificationInfoAccentBackgroundBrush" Color="#EFF6FF"/>

    <SolidColorBrush x:Key="NotificationSuccessAccentBrush" Color="#059669"/>
    <SolidColorBrush x:Key="NotificationSuccessAccentBackgroundBrush" Color="#ECFDF5"/>

    <SolidColorBrush x:Key="NotificationWarningAccentBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="NotificationWarningAccentBackgroundBrush" Color="#FFF7ED"/>

    <SolidColorBrush x:Key="NotificationErrorAccentBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="NotificationErrorAccentBackgroundBrush" Color="#FEF2F2"/>
</ResourceDictionary>