<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#181A1F"/>
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#353A45"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#101216"/>

    <!-- TitleBar -->
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#14161B"/>
    <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="#E5E7EB"/>

    <!-- Caption Buttons -->
    <SolidColorBrush x:Key="CaptionButtonHoverBrush" Color="#2A2F38"/>
    <SolidColorBrush x:Key="CaptionButtonPressedBrush" Color="#353A45"/>
    <SolidColorBrush x:Key="CloseButtonHoverBrush" Color="#E81123"/>

    <!-- Menu -->
    <SolidColorBrush x:Key="MenuBarBackgroundBrush" Color="#181A1F"/>
    <SolidColorBrush x:Key="MenuHoverBrush" Color="#2A2F38"/>
    <SolidColorBrush x:Key="MenuPressedBrush" Color="#353A45"/>
    <SolidColorBrush x:Key="MenuPopupBackgroundBrush" Color="#181A1F"/>
    <SolidColorBrush x:Key="MenuPopupBorderBrush" Color="#353A45"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A1A8B3"/>
    <SolidColorBrush x:Key="TextErrorBrush" Color="#F38BA8"/>

    <!-- Primary Button -->
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#7AA2F7"/>
    <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#6D97F0"/>
    <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#5E86DB"/>
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#0F1115"/>

    <!-- Secondary Button -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#23272E"/>
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#353A45"/>
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#2D333D"/>
    <SolidColorBrush x:Key="SecondaryButtonPressedBrush" Color="#383F4B"/>

    <!-- Danger / Cancel -->
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#23272E"/>
    <SolidColorBrush x:Key="DangerButtonForegroundBrush" Color="#F38BA8"/>
    <SolidColorBrush x:Key="DangerButtonBorderBrush" Color="#F38BA8"/>
    <SolidColorBrush x:Key="DangerButtonHoverBrush" Color="#2E2429"/>
    <SolidColorBrush x:Key="DangerButtonPressedBrush" Color="#3B2B31"/>

    <!-- Device Item -->
    <SolidColorBrush x:Key="DeviceDefaultBorderBrush" Color="#7AA2F7"/>
    <SolidColorBrush x:Key="DeviceDefaultBackgroundBrush" Color="#1B2433"/>
    <SolidColorBrush x:Key="DeviceHoverBrush" Color="#2A2F38"/>
    <SolidColorBrush x:Key="DeviceDefaultHoverBrush" Color="#22304A"/>

    <!-- Device Text -->
    <SolidColorBrush x:Key="DeviceTextNormalBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="DeviceTextDefaultBrush" Color="#8CB4FF"/>
    <SolidColorBrush x:Key="DeviceTextSubBrush" Color="#8B93A1"/>

    <!-- Dialog -->
    <SolidColorBrush x:Key="DialogBackgroundBrush" Color="#181A1F"/>
    <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#23272E"/>
    <SolidColorBrush x:Key="DialogBorderBrush" Color="#353A45"/>

    <!-- Input -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#23272E"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#353A45"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#7AA2F7"/>
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#7E8794"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#7AA2F7"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#6D97F0"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#5E86DB"/>
    <SolidColorBrush x:Key="AccentBackgroundBrush" Color="#1B2433"/>
    <SolidColorBrush x:Key="AccentStrokeBrush" Color="#42526B"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#23272E"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#353A45"/>
    <SolidColorBrush x:Key="ComboBoxHoverBrush" Color="#2D333D"/>
    <SolidColorBrush x:Key="ComboBoxDropdownBrush" Color="#181A1F"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#2A2F38"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#22304A"/>

    <!-- General -->
    <SolidColorBrush x:Key="SeparatorBrush" Color="#353A45"/>

    <CornerRadius x:Key="CornerRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLarge">10</CornerRadius>

    <Thickness x:Key="ControlPadding">18,0</Thickness>
    <Thickness x:Key="DialogPadding">20</Thickness>

    <!-- Settings / Panels -->
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#23272E"/>
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#353A45"/>
    <SolidColorBrush x:Key="PanelSubtleBackgroundBrush" Color="#181A1F"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#20242B"/>

    <!-- Device Section Accent -->
    <SolidColorBrush x:Key="SpeakerAccentBrush" Color="#A5B4FC"/>
    <SolidColorBrush x:Key="SpeakerAccentBackgroundBrush" Color="#25314A"/>
    <SolidColorBrush x:Key="MicAccentBrush" Color="#6EE7B7"/>
    <SolidColorBrush x:Key="MicAccentBackgroundBrush" Color="#1D3A35"/>

    <!-- Device Item Extended -->
    <SolidColorBrush x:Key="DeviceItemBorderBrush" Color="#4A5160"/>
    <SolidColorBrush x:Key="DeviceSelectedBackgroundBrush" Color="#1B2433"/>
    <SolidColorBrush x:Key="DeviceSelectedBorderBrush" Color="#5C7FAE"/>
    <SolidColorBrush x:Key="DeviceBadgeBackgroundBrush" Color="#8CB4FF"/>
    <SolidColorBrush x:Key="DeviceBadgeForegroundBrush" Color="#111318"/>
    <SolidColorBrush x:Key="DeviceStatusIdleBrush" Color="#7E8794"/>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#20FFFFFF"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#668B93A1"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#99B5BDC9"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#CCD5DBE3"/>

    <!-- Notification -->
    <SolidColorBrush x:Key="NotificationBackgroundBrush" Color="#2A2B3C"/>
    <SolidColorBrush x:Key="NotificationBorderBrush" Color="#45475A"/>
    <SolidColorBrush x:Key="NotificationTitleBrush" Color="#F5F7FB"/>
    <SolidColorBrush x:Key="NotificationMessageBrush" Color="#C7CAD6"/>
    <SolidColorBrush x:Key="NotificationShadowBrush" Color="#000000"/>

    <SolidColorBrush x:Key="NotificationInfoAccentBrush" Color="#89B4FA"/>
    <SolidColorBrush x:Key="NotificationInfoAccentBackgroundBrush" Color="#24324A"/>

    <SolidColorBrush x:Key="NotificationSuccessAccentBrush" Color="#6EE7B7"/>
    <SolidColorBrush x:Key="NotificationSuccessAccentBackgroundBrush" Color="#1F3B36"/>

    <SolidColorBrush x:Key="NotificationWarningAccentBrush" Color="#FBBF24"/>
    <SolidColorBrush x:Key="NotificationWarningAccentBackgroundBrush" Color="#45351F"/>

    <SolidColorBrush x:Key="NotificationErrorAccentBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="NotificationErrorAccentBackgroundBrush" Color="#4A2525"/>
</ResourceDictionary>