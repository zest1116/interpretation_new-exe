<UserControl x:Class="LGCNS.axink.App.Controls.ThemedTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:local="clr-namespace:LGCNS.axink.App.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="32">
    <Border x:Name="TitleBarBorder"
        Grid.Row="0"
        Background="{StaticResource TitleBarBackgroundBrush}"
        BorderThickness="0"
        CornerRadius="10,10,0,0">
        <Grid x:Name="TitleBar"
          MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 앱 아이콘 + 제목 -->
            <Grid x:Name="TitleLeftHost"
              Grid.Column="0"
              VerticalAlignment="Stretch"
              shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                    <Border Width="16"
                        Height="16"
                        VerticalAlignment="Center"
                        Background="Transparent">
                        <Image x:Name="AppIconImage"
                           Width="16"
                           Height="16"
                           Stretch="Uniform"
                           Source="/Assets/LGCNS.DesktopAudioHub.App.png"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <TextBlock Text="a:xink Translator"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TitleBarForegroundBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>

            <!-- 드래그 영역 -->
            <Grid Grid.Column="1"
              Background="Transparent"/>

            <!-- 우측 버튼 -->
            <StackPanel x:Name="CaptionButtonsHost"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">


                <!-- 닫기 -->
                <Button Style="{StaticResource CloseButtonStyle}"
                    Click="CloseButton_Click">
                    <Grid Width="10" Height="10" Margin="0,-1,0,0">
                        <Path Data="M 1,1 L 9,9 M 9,1 L 1,9"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.1"
                          StrokeStartLineCap="Square"
                          StrokeEndLineCap="Square"
                          SnapsToDevicePixels="True"/>
                    </Grid>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
