<UserControl x:Class="LGCNS.axink.App.Controls.NotificationItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LGCNS.axink.App.Controls"
             mc:Ignorable="d" Margin="0,0,0,4" HorizontalAlignment="Right">
    <Border x:Name="SlideBorder" Background="#F2F8FD" CornerRadius="8" Padding="14" MaxWidth="600" BorderBrush="#2F6FED" BorderThickness="0.7">
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" X="320"/>
        </Border.RenderTransform>
        <StackPanel>
            <!--<TextBlock x:Name="TitleText" Foreground="White" FontWeight="Bold" FontSize="14"/>-->
            <TextBlock x:Name="MessageText" Foreground="#323232" FontWeight="Bold" FontSize="12"
                       TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>
    </Border>

</UserControl>